// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "git": {
    "disable_git": true
  },
  "disable_ai": true,
  "icon_theme": "Zed (Default)",
  "ui_font_weight": 500.0,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 20.0
  },
  "prettier": {
    "allowed": true
  },
  "edit_predictions": {
    "provider": "none"
  },
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_project_panel": false,
    "enable_preview_from_multibuffer": false
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false
  },
  "tab_bar": {
    "show": true
  },
  "tabs": {
    "git_status": true,
    "file_icons": true
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false
  },
  "base_keymap": "VSCode",
  "soft_wrap": "editor_width",
  "agent": {
    "dock": "left",
    "button": false,
    "single_file_review": true
  },
  "ui_font_family": "JetBrainsMonoNL Nerd Font Propo",
  "buffer_font_family": "JetBrainsMonoNL Nerd Font",
  "ui_font_size": 15.0,
  "buffer_font_size": 17.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Tokyo Night Storm"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  }
}
